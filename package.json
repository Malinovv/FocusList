{
  "name": "focuslist",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "docker compose up -d postgres && concurrently -k -n api,web -c blue,green \"npm:dev:api\" \"npm:dev:web\"",
    "dev:web": "npm run dev --workspace=@focuslist/web",
    "dev:api": "npm run dev --workspace=@focuslist/api",
    "build:web": "npm run build --workspace=@focuslist/web",
    "build:api": "npm run build --workspace=@focuslist/api",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "db:generate": "npm run db:generate --workspace=@focuslist/db",
    "db:push": "npm run db:push --workspace=@focuslist/db",
    "db:migrate": "npm run db:migrate --workspace=@focuslist/db",
    "db:studio": "npm run db:studio --workspace=@focuslist/db"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
